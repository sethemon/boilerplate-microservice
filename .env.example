# ── Copy to .env and fill in real values ────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_SECRET_KEY=change-me-in-production

# ── Database (pick one, set in config/config.yaml or override here) ──────────
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/microservice_db
# MySQL
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/microservice_db
# SQL Server
# DATABASE_URL=mssql+pyodbc://user:password@localhost:1433/microservice_db?driver=ODBC+Driver+17+for+SQL+Server
# Oracle
# DATABASE_URL=oracle+cx_oracle://user:password@localhost:1521/ORCLCDB
# SQLite (local dev / tests)
# DATABASE_URL=sqlite+aiosqlite:///./dev.db

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
